{
    "$schema": "https://opencode.ai/config.json",
    "agent": {
        "lead-architect": {
            "tools": {
                "n8n-docs_*": true
            }
        }
    },
    "mcp": {
        // Login with : opencode mcp auth n8n-docs
        "n8n-docs": {
            "type": "remote",
            "url": "https://n8n.mcp.kapa.ai/",
            "enabled": true
        },
    },
    "watcher": {
        "ignore": [
            ".git/**",
            "node_modules/**",
            "dist/**",
        ]
    }
}