// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
	"name": "n8n-nodes-ovhcloud",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/typescript-node:4-24-trixie",
	"features": {
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/devcontainers-extra/features/npm-packages:1": {
			"packages": [
				"opencode-ai",
				"markdownlint-rs",
				"@code-yeongyu/comment-checker"
			]
		}
	},
	"mounts": [
		"source=n8n-data,target=/home/node/.n8n-node-cli,type=volume",
		"source=opencode-data,target=/home/node/.local/share/opencode,type=volume",
		"source=${localEnv:HOME}/.config/opencode,target=/home/node/.config/opencode,type=bind"
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"github.vscode-github-actions",
				"lemonade-sdk.lemonade-sdk",
				"yzhang.markdown-all-in-one",
				"Gruntfuggly.todo-tree"
			],
			"settings": {
				"editor.experimentalGpuAcceleration": "off",
				"terminal.integrated.gpuAcceleration": "auto"
			}
		}
	},
	"secrets": {},
	"remoteEnv": {
		"OPENCODE_ENABLE_EXA": "true",
		"N8N_LOG_LEVEL": "debug"
	},
	"postCreateCommand": {
		"n8n-volume": "sudo chown -R node:node /home/node/.n8n-node-cli",
		"local-owner": "sudo chown -R node:node /home/node/.local"
	},
	"postStartCommand": {
		"oh-my-opencode": "npx -y oh-my-opencode install --no-tui --skip-auth --claude=no --openai=no --gemini=no --copilot=yes --opencode-zen=yes"
	}
}